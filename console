--===== ERROR EXPLAIN SYSTEM =====--
local function ExplainError(msg)

	msg = string.lower(msg)

	if string.find(msg, "expected identifier") then
		return "→ Tên biến sai. Biến phải bắt đầu bằng chữ hoặc _. Không được bắt đầu bằng số."

	elseif string.find(msg, "unexpected symbol") then
		return "→ Có ký tự không hợp lệ. Kiểm tra lại dấu = , ( ) hoặc ký tự đặc biệt."

	elseif string.find(msg, "attempt to index nil") then
		return "→ Bạn đang truy cập một biến chưa tồn tại (nil). Có thể biến chưa được tạo."

	elseif string.find(msg, "attempt to call nil") then
		return "→ Đang gọi một biến như function nhưng nó là nil."

	elseif string.find(msg, "missing") then
		return "→ Thiếu từ khóa như end, then, do hoặc thiếu dấu đóng."

	elseif string.find(msg, "expected") then
		return "→ Sai cú pháp. Có thể thiếu dấu = hoặc đặt sai cấu trúc lệnh."

	elseif string.find(msg, "number expected") then
		return "→ Lệnh yêu cầu số nhưng bạn truyền vào giá trị khác."

	elseif string.find(msg, "string expected") then
		return "→ Lệnh yêu cầu chuỗi (text) nhưng bạn truyền sai kiểu dữ liệu."

	else
		return "→ Lỗi cú pháp hoặc logic trong script. Kiểm tra lại đoạn code gần đó."
	end
end

--===== ADD LOG =====--
local function AddLog(text, color, explanation)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,-5,0,24)
	label.BackgroundTransparency = 1
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Font = Enum.Font.Code
	label.TextSize = 15
	label.Text = text
	label.TextColor3 = color
	label.Parent = scroll

	if explanation then
		local explainLabel = Instance.new("TextLabel")
		explainLabel.Size = UDim2.new(1,-15,0,40)
		explainLabel.BackgroundTransparency = 1
		explainLabel.TextWrapped = true
		explainLabel.TextXAlignment = Enum.TextXAlignment.Left
		explainLabel.Font = Enum.Font.Gotham
		explainLabel.TextSize = 14
		explainLabel.Text = explanation
		explainLabel.TextColor3 = Color3.fromRGB(255,120,120)
		explainLabel.Parent = scroll
	end
end

--===== CAPTURE LOGS =====--
LogService.MessageOut:Connect(function(message, messageType)

	if messageType == Enum.MessageType.MessageOutput then
		AddLog(message, Color3.fromRGB(255,255,255))

	elseif messageType == Enum.MessageType.MessageWarning then
		AddLog(message, Color3.fromRGB(255,200,0))

	elseif messageType == Enum.MessageType.MessageError then
		local explain = ExplainError(message)
		AddLog(message, Color3.fromRGB(255,60,60), explain)
	end

end)

